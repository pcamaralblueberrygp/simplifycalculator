---
import BaseLayoutPtBr from '../../../layouts/BaseLayoutPtBr.astro';
import { BLOG_POSTS_BR } from '../../../data/blog-posts-pt-br';

const posts = [...BLOG_POSTS_BR].sort((a, b) => (a.publishDate < b.publishDate ? 1 : -1));
---

<BaseLayoutPtBr
  title="Blog"
  description="Guias e artigos sobre financiamento, dívidas, poupança e investimentos — do time do SimplifyCalculator Brasil."
  path="/pt-br/blog"
>
  <div class="static-page" style="max-width: 900px">
    <h1>Blog</h1>
    <p>Guias práticos e diretos sobre financiamento, dívidas, poupança e investimentos — escritos para complementar nossas calculadoras gratuitas.</p>

    <div style="margin-top: 32px; display: flex; flex-direction: column; gap: 28px;">
      {posts.map((post) => (
        <a href={`/pt-br/blog/${post.slug}`} style="display: flex; gap: 20px; text-decoration: none; align-items: flex-start;">
          <img src={post.image.src} alt={post.image.alt} width="160" height="84" style="border-radius: 8px; flex-shrink: 0; object-fit: cover;" loading="lazy" />
          <div>
            <div style="font-size: 12.5px; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: 0.03em;">{post.category}</div>
            <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 19px; font-weight: 600; color: var(--ink); margin: 4px 0;">{post.title}</h2>
            <p style="font-size: 14px; color: var(--text-muted); margin: 0;">{post.metaDescription}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayoutPtBr>
