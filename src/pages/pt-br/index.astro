---
import BaseLayoutPtBr from '../../layouts/BaseLayoutPtBr.astro';
import { CALCULATORS_BR } from '../../data/calculators-pt-br';

const categories = Array.from(new Set(CALCULATORS_BR.map((c) => c.category)));
---

<BaseLayoutPtBr
  title="Calculadoras Financeiras Gratuitas para o Brasil"
  description="Calculadoras financeiras gratuitas adaptadas às regras do Brasil: financiamento, Tabela Price, salário líquido CLT, CLT x PJ, aposentadoria e mais."
  path="/pt-br/"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-left">
        <div class="hero-badge">Feito com as regras do Brasil</div>
        <h1>Entenda o custo real de qualquer financiamento antes de assinar.</h1>
        <p class="hero-copy">
          Calculadoras em português para financiamento, Tabela Price, salário líquido CLT,
          comparação CLT x PJ, aposentadoria e quitação de dívidas — com as regras reais do
          Brasil (INSS, IRRF, SELIC, Simples Nacional).
        </p>
        <div class="hero-cta">
          <a href="/pt-br/calculadoras/calculadora-de-financiamento" class="btn-primary">Começar a calcular — grátis</a>
          <a href="#calculadoras" class="btn-text">Ver todas as calculadoras →</a>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-calc-card">
          <div class="hcc-header">
            <span class="hcc-header-title">Calculadora de financiamento</span>
            <span class="hcc-tag">/ Tabela Price</span>
          </div>
          <div class="hcc-body">
            <div>
              <div class="hcc-label">Valor do Empréstimo</div>
              <div class="hcc-input-row">
                <input type="number" id="hcc-br-amount" value="15000" min="1000" step="500" />
                <span class="hcc-unit">R$</span>
              </div>
            </div>
            <div class="hcc-two-up">
              <div>
                <div class="hcc-label">Taxa (a.m.)</div>
                <div class="hcc-input-row">
                  <input type="number" id="hcc-br-rate" value="2.5" min="0.1" max="30" step="0.1" />
                  <span class="hcc-unit">%</span>
                </div>
              </div>
              <div>
                <div class="hcc-label">Prazo</div>
                <div class="hcc-input-row">
                  <input type="number" id="hcc-br-term" value="24" min="1" max="360" step="1" />
                  <span class="hcc-unit">mês</span>
                </div>
              </div>
            </div>
            <div class="hcc-progress-track">
              <div class="hcc-progress-fill" id="hcc-br-progress" style="width: 30%"></div>
            </div>
            <div class="hcc-result">
              <div>
                <div class="hcc-result-label">Parcela Mensal</div>
                <div class="hcc-result-main" id="hcc-br-payment">R$ 833</div>
              </div>
              <div class="hcc-result-secondary">
                <div class="hcc-result-label">Total de Juros</div>
                <div class="hcc-result-sub" id="hcc-br-interest">R$ 4.996</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <div class="trust-strip">
    <div class="container">
      <span>11 calculadoras</span>
      <span>·</span>
      <span>Sem cadastro</span>
      <span>·</span>
      <span>Regras do Brasil (INSS, IRRF, SELIC)</span>
      <span>·</span>
      <span>Atualizado 2026</span>
    </div>
  </div>

  <!-- Popular calculators -->
  <section class="section" id="calculadoras" style="padding-top: 48px">
    <div class="container">
      <div class="eyebrow">Todas as calculadoras</div>
      <h2 class="section-h2">Cada ferramenta, por categoria</h2>
      {categories.map((category) => (
        <div style="margin-bottom: 40px">
          <h3 style="font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 600; color: var(--ink); margin-bottom: 14px; padding-bottom: 8px; border-bottom: 1px solid var(--border);">{category}</h3>
          <div class="calc-grid">
            {CALCULATORS_BR.filter((c) => c.category === category).map((calc) => (
              <a class="calc-tile" href={`/pt-br/calculadoras/${calc.slug}`}>
                <h3>{calc.shortTitle}</h3>
                <p>{calc.metaDescription.slice(0, 80)}…</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Guias -->
  <section class="section" style="background: var(--bg-soft)">
    <div class="container">
      <div class="eyebrow">Guias</div>
      <h2 class="section-h2">Guias financeiros, explicados sem enrolação</h2>
      <div class="guide-article">
        <h3>SAC ou Price: Qual Sistema de Amortização Escolher no Financiamento Imobiliário?</h3>
        <p>
          Quem já pesquisou financiamento imobiliário no Brasil provavelmente já ouviu essa
          pergunta: SAC ou Tabela Price? Os dois sistemas calculam a mesma dívida de formas
          diferentes, e a escolha errada pode significar pagar dezenas de milhares de reais a mais
          em juros ao longo de 20 ou 30 anos.
        </p>
        <p>
          <strong>No SAC (Sistema de Amortização Constante)</strong>, a parcela de amortização
          (a parte que reduz o saldo devedor) é sempre a mesma todo mês. Como os juros incidem
          sobre o saldo devedor, e esse saldo cai de forma constante, a parcela total começa mais
          alta e vai diminuindo mês a mês. O resultado prático: quem escolhe o SAC paga mais no
          início do contrato, mas menos no total ao longo dos anos, porque o saldo devedor cai mais
          rápido logo nos primeiros anos — que é exatamente quando mais juros se acumulariam se o
          saldo ficasse alto por mais tempo.
        </p>
        <p>
          <strong>Na Tabela Price</strong>, a parcela é sempre igual do primeiro ao último mês — o
          que muda é a proporção entre juros e amortização dentro de cada parcela. Isso torna o
          planejamento financeiro mais previsível, já que você sabe exatamente quanto vai pagar
          todo mês pelos próximos anos. Mas, no total, a Tabela Price costuma gerar mais juros
          pagos ao longo do contrato do que o SAC, porque o saldo devedor demora mais para cair de
          forma significativa.
        </p>
        <p>
          Na prática, a escolha depende do seu momento financeiro: se seu orçamento consegue
          absorver uma parcela inicial mais alta, o SAC tende a ser mais barato no total. Se você
          precisa de uma parcela mais previsível e talvez mais baixa no começo, a Price facilita o
          planejamento — ainda que custe mais juros no total. Use nossa
          <a href="/pt-br/calculadoras/calculadora-de-financiamento-imobiliario">Calculadora de
          Financiamento Imobiliário</a> para comparar os dois sistemas lado a lado com os seus
          números reais antes de assinar qualquer contrato, e a
          <a href="/pt-br/calculadoras/tabela-price-calculadora">Calculadora de Tabela Price</a>
          para ver o detalhamento mês a mês de como a Price se comporta no seu caso específico.
        </p>
      </div>

      <div class="guide-article" style="margin-top: 40px">
        <h3>CLT ou PJ: Guia Completo para Decidir com Números na Mão</h3>
        <p>
          Receber uma proposta de trabalho como Pessoa Jurídica (PJ) em vez de CLT é cada vez mais
          comum no Brasil, especialmente em tecnologia, marketing e consultoria. A decisão parece
          simples à primeira vista — "quanto eu ganho líquido em cada opção?" — mas a resposta
          completa exige olhar além do valor bruto anunciado.
        </p>
        <p>
          <strong>Na CLT</strong>, o salário bruto sofre descontos obrigatórios de INSS e IRRF, mas
          em troca você recebe benefícios com valor financeiro real: 13º salário, férias remuneradas
          com adicional de 1/3, FGTS depositado mensalmente (8% do salário), estabilidade em certas
          situações, seguro-desemprego em caso de demissão sem justa causa, e direito a verbas
          rescisórias. Quando somamos o valor mensal equivalente desses benefícios ao salário
          líquido, o "valor mensal total" de um cargo CLT costuma ser 25-35% maior que o salário
          líquido isolado sugere.
        </p>
        <p>
          <strong>No regime PJ</strong>, você fatura como uma empresa (geralmente enquadrada no
          Simples Nacional), paga uma alíquota sobre o faturamento, arca com o custo de um contador,
          contribui para o INSS como contribuinte individual (sem o mesmo teto de benefícios da
          CLT) e não tem nenhum dos benefícios trabalhistas mencionados acima. Em compensação, o
          faturamento PJ costuma ser oferecido com um valor nominal mais alto que o salário CLT
          equivalente, justamente para compensar essa diferença.
        </p>
        <p>
          A regra prática usada por muitos profissionais: um faturamento PJ só compensa
          financeiramente se for pelo menos 30-50% maior que o salário bruto CLT equivalente —
          e isso antes de considerar fatores não financeiros como estabilidade, previsibilidade de
          renda e acesso a crédito (bancos costumam exigir mais documentação e garantias de quem
          é PJ). Use nossa <a href="/pt-br/calculadoras/calculadora-clt-vs-pj">Calculadora CLT x
          PJ</a> para comparar as duas propostas com números reais, incluindo o custo do contador e
          a alíquota do Simples Nacional, antes de tomar essa decisão.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-center">
    <div class="container">
      <div class="eyebrow">Perguntas Frequentes</div>
      <h2 class="section-h2">Perguntas, respondidas</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-trigger">
            <span class="faq-trigger-text">As calculadoras são realmente gratuitas?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">Sim, 100% gratuitas. Sem cadastro, sem cartão de crédito, sem período de teste. Todas as calculadoras do SimplifyCalculator são gratuitas para usar quantas vezes quiser.</div>
        </div>
        <div class="faq-item">
          <button class="faq-trigger">
            <span class="faq-trigger-text">Vocês armazenam meus dados financeiros?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">Não. Todos os cálculos rodam no seu navegador. Os números que você digita nunca saem do seu dispositivo — não coletamos, armazenamos ou transmitimos nenhuma informação financeira sua.</div>
        </div>
        <div class="faq-item">
          <button class="faq-trigger">
            <span class="faq-trigger-text">As calculadoras usam as regras atuais do Brasil?</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">Sim. Usamos as tabelas de INSS e IRRF vigentes, a regra atual da poupança vinculada à SELIC, e os sistemas de amortização (SAC e Tabela Price) usados pelos bancos brasileiros. Ainda assim, sempre confirme valores importantes com seu banco ou contador.</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayoutPtBr>

<script>
  // Calculadora ao vivo do hero
  function hccBrCalc() {
    const valor = parseFloat((document.getElementById('hcc-br-amount') as HTMLInputElement)?.value) || 0;
    const taxaMensal = parseFloat((document.getElementById('hcc-br-rate') as HTMLInputElement)?.value) || 0;
    const prazo = parseInt((document.getElementById('hcc-br-term') as HTMLInputElement)?.value) || 1;
    const i = taxaMensal / 100;
    const pmt = i > 0 ? valor * i * Math.pow(1 + i, prazo) / (Math.pow(1 + i, prazo) - 1) : valor / prazo;
    const totalJuros = pmt * prazo - valor;
    const fmt = (n: number) => 'R$ ' + Math.max(0, n).toLocaleString('pt-BR', { maximumFractionDigits: 0 });
    const payEl = document.getElementById('hcc-br-payment');
    const intEl = document.getElementById('hcc-br-interest');
    const prog = document.getElementById('hcc-br-progress');
    if (payEl) payEl.textContent = fmt(pmt);
    if (intEl) intEl.textContent = fmt(totalJuros);
    if (prog) (prog as HTMLElement).style.width = Math.min(100, (prazo / 360) * 100) + '%';
  }
  ['hcc-br-amount','hcc-br-rate','hcc-br-term'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', hccBrCalc);
  });
  hccBrCalc();

  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!;
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });
</script>
