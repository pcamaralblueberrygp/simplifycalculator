---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy policy for SimplifyCalculator."
  path="/privacy-policy"
>
  <div class="static-page">
    <h1>Privacy Policy</h1>
    <p><em>Last updated: July 17, 2026</em></p>
    <p>
      This site does not require an account and does not store the values you enter into any
      calculator — all calculations run locally in your browser.
    </p>
    <p>
      We use Google AdSense to display ads. Google and its partners may use cookies or similar
      technologies to serve ads based on your prior visits to this or other websites. You can
      opt out of personalized advertising by visiting
      <a href="https://adssettings.google.com" target="_blank" rel="noopener">Google Ads Settings</a>.
    </p>
    <p>
      This site may use Google Analytics or a similar service to understand aggregate traffic
      patterns. No personally identifying information is sold.
    </p>
    <p>
      If you have questions about this policy, contact
      <a href="mailto:contact@simplifycalculator.com">contact@simplifycalculator.com</a>.
    </p>
  </div>
</BaseLayout>
