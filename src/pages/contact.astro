---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with the SimplifyCalculator team — questions, bug reports, and calculator suggestions welcome."
  path="/contact"
>
  <div class="static-page">
    <h1>Contact Us</h1>
    <p>
      We'd love to hear from you — whether you spotted a bug in a calculator, have a
      suggestion for a new one, or just have a question about how something works.
    </p>
    <p>
      Email us at <a href="mailto:contact@simplifycalculator.com">contact@simplifycalculator.com</a>
      and we'll get back to you as soon as we can.
    </p>
  </div>
</BaseLayout>
