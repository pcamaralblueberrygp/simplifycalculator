---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About SimplifyCalculator — free financial calculators."
  path="/about"
>
  <div class="static-page">
    <h1>About SimplifyCalculator</h1>
    <p>
      SimplifyCalculator builds free, no-signup calculators to help people understand loans,
      mortgages, savings, and debt before making real financial decisions. Every calculator
      on this site runs entirely in your browser — we don't collect or store the numbers you
      enter.
    </p>
    <p>
      Have a calculator you'd like to see, or spotted a bug in the math? Reach out at
      <a href="mailto:contact@simplifycalculator.com">contact@simplifycalculator.com</a> or visit
      our <a href="/contact">contact page</a>.
    </p>
  </div>
</BaseLayout>
