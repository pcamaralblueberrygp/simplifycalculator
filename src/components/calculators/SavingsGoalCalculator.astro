---
// Required monthly contribution to hit a savings goal by a target date.
---
<form class="calc-form" id="calc-form">
  <div class="field">
    <label for="goal">Savings goal ($)</label>
    <input type="number" id="goal" min="0" step="0.01" value="30000" required />
  </div>
  <div class="field">
    <label for="current">Current savings ($)</label>
    <input type="number" id="current" min="0" step="0.01" value="4000" />
  </div>
  <div class="field">
    <label for="rate">Expected annual return (%)</label>
    <input type="number" id="rate" min="0" step="0.01" value="4" required />
  </div>
  <div class="field">
    <label for="months">Time until goal (months)</label>
    <input type="number" id="months" min="1" step="1" value="60" required />
  </div>
  <button type="submit">Calculate required savings</button>
</form>

<div class="result-box" id="result-box">
  <div class="headline" id="r-monthly"></div>
  <div class="row"><span>Total you'll contribute</span><span id="r-contributed"></span></div>
  <div class="row"><span>Growth from interest</span><span id="r-growth"></span></div>
</div>

<script>
  const fmt = (n: number) =>
    new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(n);

  const form = document.getElementById('calc-form') as HTMLFormElement;
  const resultBox = document.getElementById('result-box') as HTMLDivElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const goal = parseFloat((document.getElementById('goal') as HTMLInputElement).value);
    const current = parseFloat(
      (document.getElementById('current') as HTMLInputElement).value || '0'
    );
    const annualRate = parseFloat((document.getElementById('rate') as HTMLInputElement).value);
    const months = parseInt((document.getElementById('months') as HTMLInputElement).value, 10);

    const r = annualRate / 100 / 12;
    let pmt: number;
    if (r === 0) {
      pmt = (goal - current) / months;
    } else {
      const futureValueOfCurrent = current * Math.pow(1 + r, months);
      pmt = ((goal - futureValueOfCurrent) * r) / (Math.pow(1 + r, months) - 1);
    }
    pmt = Math.max(pmt, 0);
    const contributed = current + pmt * months;
    const growth = goal - contributed;

    (document.getElementById('r-monthly') as HTMLDivElement).textContent =
      fmt(pmt) + ' / month needed';
    (document.getElementById('r-contributed') as HTMLSpanElement).textContent = fmt(contributed);
    (document.getElementById('r-growth') as HTMLSpanElement).textContent = fmt(growth);
    resultBox.classList.add('visible');
  });
</script>
