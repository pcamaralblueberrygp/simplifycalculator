---
// Year-by-year amortization schedule for a fixed-rate loan.
---
<form class="calc-form" id="calc-form">
  <div class="field">
    <label for="amount">Loan amount ($)</label>
    <input type="number" id="amount" min="0" step="0.01" value="250000" required />
  </div>
  <div class="field">
    <label for="rate">Annual interest rate (%)</label>
    <input type="number" id="rate" min="0" step="0.01" value="6" required />
  </div>
  <div class="field">
    <label for="term">Loan term (years)</label>
    <input type="number" id="term" min="1" step="1" value="30" required />
  </div>
  <button type="submit">Generate schedule</button>
</form>

<div class="result-box" id="result-box">
  <div class="headline" id="r-payment"></div>
  <div class="row"><span>Total interest over the loan</span><span id="r-interest"></span></div>
  <div class="schedule-wrap">
    <table class="schedule">
      <thead>
        <tr>
          <th>Year</th>
          <th>Principal paid</th>
          <th>Interest paid</th>
          <th>Remaining balance</th>
        </tr>
      </thead>
      <tbody id="r-schedule-body"></tbody>
    </table>
  </div>
</div>

<script>
  const fmt = (n: number) =>
    new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(n);

  const form = document.getElementById('calc-form') as HTMLFormElement;
  const resultBox = document.getElementById('result-box') as HTMLDivElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const amount = parseFloat((document.getElementById('amount') as HTMLInputElement).value);
    const annualRate = parseFloat((document.getElementById('rate') as HTMLInputElement).value);
    const years = parseInt((document.getElementById('term') as HTMLInputElement).value, 10);

    const months = years * 12;
    const r = annualRate / 100 / 12;
    let payment: number;
    if (r === 0) {
      payment = amount / months;
    } else {
      payment = (amount * r * Math.pow(1 + r, months)) / (Math.pow(1 + r, months) - 1);
    }

    let balance = amount;
    let totalInterest = 0;
    const rows: { year: number; principal: number; interest: number; balance: number }[] = [];

    for (let y = 1; y <= years; y++) {
      let yearPrincipal = 0;
      let yearInterest = 0;
      for (let m = 0; m < 12; m++) {
        if (balance <= 0) break;
        const interestThisMonth = balance * r;
        let principalThisMonth = payment - interestThisMonth;
        if (principalThisMonth > balance) principalThisMonth = balance;
        balance -= principalThisMonth;
        yearPrincipal += principalThisMonth;
        yearInterest += interestThisMonth;
      }
      totalInterest += yearInterest;
      rows.push({ year: y, principal: yearPrincipal, interest: yearInterest, balance });
    }

    (document.getElementById('r-payment') as HTMLDivElement).textContent =
      fmt(payment) + ' / month';
    (document.getElementById('r-interest') as HTMLSpanElement).textContent = fmt(totalInterest);

    const tbody = document.getElementById('r-schedule-body') as HTMLTableSectionElement;
    tbody.innerHTML = rows
      .map(
        (row) =>
          `<tr><td>${row.year}</td><td>${fmt(row.principal)}</td><td>${fmt(
            row.interest
          )}</td><td>${fmt(Math.max(row.balance, 0))}</td></tr>`
      )
      .join('');

    resultBox.classList.add('visible');
  });
</script>
