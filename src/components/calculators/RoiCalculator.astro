---
// Total ROI and annualized ROI.
---
<form class="calc-form" id="calc-form">
  <div class="field">
    <label for="initial">Initial investment ($)</label>
    <input type="number" id="initial" min="0.01" step="0.01" value="8000" required />
  </div>
  <div class="field">
    <label for="final">Final value ($)</label>
    <input type="number" id="final" min="0" step="0.01" value="11200" required />
  </div>
  <div class="field">
    <label for="years">Holding period (years, optional)</label>
    <input type="number" id="years" min="0" step="0.1" value="3" />
    <p class="hint">Leave at 0 to skip the annualized ROI calculation.</p>
  </div>
  <button type="submit">Calculate ROI</button>
</form>

<div class="result-box" id="result-box">
  <div class="headline" id="r-roi"></div>
  <div class="row"><span>Net gain / loss</span><span id="r-gain"></span></div>
  <div class="row" id="r-annual-row" style="display:none;">
    <span>Annualized ROI</span><span id="r-annual"></span>
  </div>
</div>

<script>
  const fmt = (n: number) =>
    new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(n);
  const pct = (n: number) => n.toFixed(2) + '%';

  const form = document.getElementById('calc-form') as HTMLFormElement;
  const resultBox = document.getElementById('result-box') as HTMLDivElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const initial = parseFloat((document.getElementById('initial') as HTMLInputElement).value);
    const final = parseFloat((document.getElementById('final') as HTMLInputElement).value);
    const years = parseFloat((document.getElementById('years') as HTMLInputElement).value || '0');

    const gain = final - initial;
    const roi = (gain / initial) * 100;

    (document.getElementById('r-roi') as HTMLDivElement).textContent = pct(roi) + ' ROI';
    (document.getElementById('r-gain') as HTMLSpanElement).textContent = fmt(gain);

    const annualRow = document.getElementById('r-annual-row') as HTMLDivElement;
    if (years > 0) {
      const annualized = (Math.pow(final / initial, 1 / years) - 1) * 100;
      (document.getElementById('r-annual') as HTMLSpanElement).textContent = pct(annualized);
      annualRow.style.display = 'flex';
    } else {
      annualRow.style.display = 'none';
    }

    resultBox.classList.add('visible');
  });
</script>
